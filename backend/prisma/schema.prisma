generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URL")
}

model User {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  phone              String        @unique
  language           String        @default("hi")
  profile            Json?
  fullProfile        Json?
  profileLastUpdated DateTime?
  schemeHistory      Json?
  createdAt          DateTime      @default(now())
  chatLogs           ChatLog[]
  applications       Application[]
}

model Scheme {
  id                      String        @id @default(auto()) @map("_id") @db.ObjectId
  name                    String        @unique
  nameHindi               String        @default("")
  category                String        @default("general")
  eligibilityCriteriaText String
  description             String        @default("")
  descriptionHindi        String        @default("")
  officialWebsite         String        @default("")
  pdfUrl                  String
  applications            Application[]
}

model FormTemplate {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  schemeName         String   @unique
  schemeNameHindi    String   @default("")
  officialPdfUrl     String
  officialWebsite    String   @default("")
  description        String   @default("")
  descriptionHindi   String   @default("")
  category           String   @default("general")
  extractedFields    Json
  eligibilityCriteria Json?
  totalFields        Int      @default(0)
  sections           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ChatLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  message   String
  timestamp DateTime @default(now())
  sender    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Application {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  schemeId     String    @db.ObjectId
  status       String    @default("pending")
  formUrl      String?
  filledFields Json?
  downloadedAt DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheme       Scheme    @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schemeId])
}

model ExamSubscription {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  examId     String
  examName   String
  category   String   @default("")
  alertTypes Json     @default("[]") // ["deadline", "admit_card", "result"]
  email      String   @default("")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([examId])
}

model CrawlRun {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  runType         String   @default("schemes") // schemes | exams | full
  status          String   @default("running") // running | completed | failed
  schemesFound    Int      @default(0)
  schemesNew      Int      @default(0)
  schemesUpdated  Int      @default(0)
  portalsCrawled  Int      @default(0)
  portalsFailed   Int      @default(0)
  error           String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
}
